{
  "name": "datepicker-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": ["apps/*"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:vue": "npm run dev --workspace=apps/vue",
    "dev:react": "npm run dev --workspace=apps/react",
    "build:vue": "npm run build --workspace=apps/vue",
    "build:react": "npm run build --workspace=apps/react",
    "lint:vue": "npm run lint --workspace=apps/vue",
    "lint:react": "npm run lint --workspace=apps/react",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"apps/**/src/**/*.{ts,tsx,vue,css}\""
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vue/tsconfig": "^0.9.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  }
}
